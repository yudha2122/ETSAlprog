<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DaerahRawanBanjir.FaceVerificationPage"
             Title="Verifikasi Wajah"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#0B2E58">

    <ScrollView>
        <VerticalStackLayout Padding="30"
                             Spacing="16"
                             VerticalOptions="Center">

            <Label Text="VERIFIKASI KEAMANAN WAJAH"
                   FontSize="26"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   TextColor="White" />

            <Label Text="SISTEM ANALISIS DAERAH RISIKO RAWAN BANJIR"
                   FontSize="14"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   TextColor="#8DD9FF" />

            <Frame Padding="22"
                   CornerRadius="12"
                   HasShadow="False"
                   BackgroundColor="#123E70"
                   BorderColor="#1F6FA8">

                <VerticalStackLayout Spacing="18">

                    <Label Text="VERIFIKASI WAJAH"
                           FontSize="22"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="White" />

                    <Label Text="Tekan tombol kamera untuk mengambil foto wajah dan melakukan verifikasi."
                           FontSize="14"
                           HorizontalTextAlignment="Center"
                           TextColor="#D8F3FF"
                           LineBreakMode="WordWrap" />

                    <Frame Padding="12"
                           CornerRadius="8"
                           HasShadow="False"
                           BackgroundColor="#0B2E58"
                           BorderColor="#1F6FA8">

                        <VerticalStackLayout Spacing="6">

                            <Label Text="Data Wajah Referensi"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#8DD9FF" />

                            <Label x:Name="LabelRegisteredInfo"
                                   Text="Data wajah referensi: -"
                                   FontSize="13"
                                   TextColor="White"
                                   HorizontalTextAlignment="Center" />

                        </VerticalStackLayout>

                    </Frame>

                    <Label x:Name="LabelVerificationResult"
                           Text="Status: belum diverifikasi"
                           FontSize="14"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           TextColor="#FFD868" />

                    <Button Text="📷 Verifikasi dengan Kamera"
                            Clicked="OnVerifyWithCameraClicked"
                            BackgroundColor="#238DF3"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="8"
                            HeightRequest="50" />

                    <Button Text="Batal"
                            Clicked="OnCancelClicked"
                            BackgroundColor="Transparent"
                            TextColor="#FF806E"
                            FontAttributes="Bold"
                            HeightRequest="45" />

                </VerticalStackLayout>

            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>